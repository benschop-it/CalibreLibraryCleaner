<Window x:Class="CalibreLibraryCleaner.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibre Library Cleaner"
        Width="1100"
        Height="700"
        MinWidth="760"
        MinHeight="480">
  <Window.InputBindings>
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NextMetadataDuplicateGroupCommand}" />
    <KeyBinding Key="P" Modifiers="Control" Command="{Binding PreviousMetadataDuplicateGroupCommand}" />
    <KeyBinding Key="D" Modifiers="Control" Command="{Binding ToggleMetadataDuplicateDeferredCommand}" />
  </Window.InputBindings>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="2*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0"
             Target="{Binding ElementName=LibraryPathBox}"
             Content="_Library folder:" />
      <TextBox x:Name="LibraryPathBox"
               Grid.Column="1"
               Margin="4,0,8,0"
               Padding="4"
               IsReadOnly="True"
               Text="{Binding SelectedLibraryPath, Mode=OneWay}"
               AutomationProperties.Name="Selected Calibre library folder" />
      <Button Grid.Column="2"
              MinWidth="80"
              Margin="0,0,8,0"
              Padding="8,4"
              Content="_Browse..."
              Command="{Binding SelectLibraryCommand}"
              AutomationProperties.Name="Browse for Calibre library" />
      <Button Grid.Column="3"
              MinWidth="80"
              Margin="0,0,8,0"
              Padding="8,4"
              Content="_Scan"
              Command="{Binding ScanCommand}" />
      <Button Grid.Column="4"
              MinWidth="80"
              Padding="8,4"
              Content="_Cancel"
              Command="{Binding CancelCommand}" />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,12,0,0">
      <ProgressBar Height="16"
                   Minimum="0"
                   Maximum="100"
                   Value="{Binding ProgressPercentage, Mode=OneWay}"
                   IsIndeterminate="{Binding IsProgressIndeterminate}"
                   AutomationProperties.Name="Library scan progress" />
      <TextBlock Margin="0,4,0,0"
                 Text="{Binding StatusMessage}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="8"
            BorderBrush="DarkRed"
            BorderThickness="1">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel>
        <TextBlock FontWeight="Bold"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding ErrorAction}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <TabControl Grid.Row="3" Grid.RowSpan="2" Margin="0,12,0,0">
      <TabItem Header="_Library">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
          </Grid.RowDefinitions>
          <GroupBox Grid.Row="0" Header="Books">
            <DataGrid ItemsSource="{Binding Books}"
                      SelectedItem="{Binding SelectedBook}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      AutomationProperties.Name="Loaded books">
              <DataGrid.Columns>
                <DataGridTextColumn Width="70" Header="ID" Binding="{Binding Id}" />
                <DataGridTextColumn Width="2*" Header="Title" Binding="{Binding Title}" />
                <DataGridTextColumn Width="2*" Header="Authors" Binding="{Binding Authors}" />
                <DataGridTextColumn Width="2*" Header="Author sort" Binding="{Binding AuthorSort}" />
                <DataGridTextColumn Width="3*" Header="Managed directory" Binding="{Binding RelativeDirectory}" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
          <GroupBox Grid.Row="1" Margin="0,8,0,0" Header="Formats for selected book">
            <DataGrid ItemsSource="{Binding SelectedFormats}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AutomationProperties.Name="Formats for selected book">
              <DataGrid.Columns>
                <DataGridTextColumn Width="80" Header="Format" Binding="{Binding Format}" />
                <DataGridTextColumn Width="*" Header="Stored name" Binding="{Binding StoredFileName}" />
                <DataGridTextColumn Width="2*" Header="Expected relative path" Binding="{Binding ExpectedRelativePath}" />
                <DataGridTextColumn Width="150" Header="File status" Binding="{Binding Status}" />
                <DataGridTextColumn Width="110" Header="Size" Binding="{Binding FileSize}" />
                <DataGridTextColumn Width="3*" Header="SHA-256" Binding="{Binding Sha256}" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
        </Grid>
      </TabItem>
      <TabItem Header="_Exact file duplicates">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="These groups contain byte-identical files. They do not by themselves identify duplicate book records."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding ExactDuplicateSummary}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <GroupBox Grid.Row="1" Header="Exact binary file groups">
            <DataGrid ItemsSource="{Binding ExactDuplicateGroups}"
                      SelectedItem="{Binding SelectedExactDuplicateGroup}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      AutomationProperties.Name="Exact binary duplicate file groups">
              <DataGrid.Columns>
                <DataGridTextColumn Width="110" Header="Size" Binding="{Binding FileSize}" />
                <DataGridTextColumn Width="90" Header="Files" Binding="{Binding FileCount}" />
                <DataGridTextColumn Width="90" Header="Records" Binding="{Binding RecordCount}" />
                <DataGridTextColumn Width="3*" Header="SHA-256" Binding="{Binding Sha256}" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
          <GroupBox Grid.Row="2" Margin="0,8,0,0" Header="Records and formats in selected file group">
            <DataGrid ItemsSource="{Binding SelectedExactDuplicateMembers}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AutomationProperties.Name="Records and formats in selected exact file group">
              <DataGrid.Columns>
                <DataGridTextColumn Width="80" Header="Record ID" Binding="{Binding BookId}" />
                <DataGridTextColumn Width="2*" Header="Title" Binding="{Binding Title}" />
                <DataGridTextColumn Width="2*" Header="Authors" Binding="{Binding Authors}" />
                <DataGridTextColumn Width="90" Header="Format" Binding="{Binding Format}" />
                <DataGridTextColumn Width="3*" Header="Relative path" Binding="{Binding ExpectedRelativePath}" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
        </Grid>
      </TabItem>
      <TabItem Header="_Metadata candidates">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="These records have exactly equal normalized titles and author sets. This is metadata evidence only; content and editions may differ."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Text="Identifiers shown below are context only and do not affect grouping. Deferred state is kept only for this application session."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding MetadataDuplicateSummary}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding StaleOverrideSummary}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="Previous stale recommendation choices" />
            <WrapPanel Margin="0,8,0,0">
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Accept generated" Command="{Binding AcceptRecommendationCommand}" AutomationProperties.HelpText="Accept the unchanged generated recommendation" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="Save _adjustments" Command="{Binding SaveManualAdjustmentCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Keep separate" Command="{Binding KeepSeparateRecommendationCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Not duplicates" Command="{Binding MarkNotDuplicatesCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Reset generated" Command="{Binding ResetRecommendationCommand}" />
              <Button Padding="8,4" Content="_Export JSON" Command="{Binding ExportRecommendationsCommand}" AutomationProperties.HelpText="Export a non-destructive review artifact outside the Calibre library" />
            </WrapPanel>
          </StackPanel>
          <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Target="{Binding ElementName=MetadataFilterBox}" Content="_Filter:" />
            <TextBox x:Name="MetadataFilterBox"
                     Grid.Column="1"
                     Margin="4,0,8,0"
                     Padding="4"
                     Text="{Binding MetadataDuplicateFilterText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                     AutomationProperties.Name="Filter metadata candidate groups" />
            <Label Grid.Column="2" Target="{Binding ElementName=MetadataFilterModeBox}" Content="_View:" />
            <ComboBox x:Name="MetadataFilterModeBox"
                      Grid.Column="3"
                      MinWidth="100"
                      Margin="4,0,8,0"
                      ItemsSource="{Binding MetadataDuplicateFilterModes}"
                      SelectedItem="{Binding MetadataDuplicateFilterMode}" />
            <Button Grid.Column="4"
                    Margin="0,0,8,0"
                    Padding="8,4"
                    Content="_Previous"
                    ToolTip="Previous visible metadata group (Ctrl+P)"
                    Command="{Binding PreviousMetadataDuplicateGroupCommand}" />
            <Button Grid.Column="5"
                    Margin="0,0,8,0"
                    Padding="8,4"
                    Content="_Next"
                    ToolTip="Next visible metadata group (Ctrl+N)"
                    Command="{Binding NextMetadataDuplicateGroupCommand}" />
            <Button Grid.Column="6"
                    MinWidth="80"
                    Padding="8,4"
                    Content="{Binding MetadataDeferAction}"
                    ToolTip="Defer or restore the selected metadata group for this session (Ctrl+D)"
                    Command="{Binding ToggleMetadataDuplicateDeferredCommand}" />
          </Grid>
          <GroupBox Grid.Row="2" Header="Exact normalized metadata candidate groups">
            <DataGrid ItemsSource="{Binding MetadataDuplicateGroups}"
                      SelectedItem="{Binding SelectedMetadataDuplicateGroup}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      AutomationProperties.Name="Exact normalized metadata candidate groups">
              <DataGrid.Columns>
                <DataGridTextColumn Width="2*" Header="Normalized title" Binding="{Binding NormalizedTitle}" />
                <DataGridTextColumn Width="2*" Header="Normalized author set" Binding="{Binding NormalizedAuthors}" />
                <DataGridTextColumn Width="80" Header="Records" Binding="{Binding RecordCount}" />
                <DataGridTextColumn Width="130" Header="Review state" Binding="{Binding ReviewStatus}" />
                <DataGridTextColumn Width="110" Header="Confidence" Binding="{Binding Confidence}" />
                <DataGridTextColumn Width="90" Header="Freshness" Binding="{Binding Freshness}" />
                <DataGridTextColumn Width="80" Header="Warnings" Binding="{Binding WarningCount}" />
                <DataGridCheckBoxColumn Width="85" Header="Overridden" Binding="{Binding IsOverridden}" />
                <DataGridTextColumn Width="2*" Header="Category" Binding="{Binding Category}" />
                <DataGridTextColumn Width="3*" Header="Match reason" Binding="{Binding Reason}" />
              </DataGrid.Columns>
            </DataGrid>
          </GroupBox>
          <TabControl Grid.Row="3" Margin="0,8,0,0">
            <TabItem Header="_Records and metadata">
              <Grid Margin="4">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                  <Label Target="{Binding ElementName=MetadataSourceBox}" Content="Reviewed metadata _source:" />
                  <ComboBox x:Name="MetadataSourceBox" MinWidth="160" ItemsSource="{Binding SelectedMetadataSourceOptions}" SelectedItem="{Binding ReviewedMetadataSource}" DisplayMemberPath="Label" />
                  <TextBlock Margin="12,4,0,0" Text="Generated and reviewed selections remain separate; stored metadata is never rewritten." TextWrapping="Wrap" />
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedMetadataDuplicateMembers}" AutoGenerateColumns="False" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling" AutomationProperties.Name="Records in selected exact metadata candidate group">
                  <DataGrid.Columns>
                    <DataGridCheckBoxColumn Width="105" Header="Retain separate" Binding="{Binding IsRetainedSeparate}" />
                    <DataGridTextColumn IsReadOnly="True" Width="70" Header="Record ID" Binding="{Binding BookId}" />
                    <DataGridTextColumn IsReadOnly="True" Width="2*" Header="Original title" Binding="{Binding Title}" />
                    <DataGridTextColumn IsReadOnly="True" Width="2*" Header="Original authors" Binding="{Binding Authors}" />
                    <DataGridTextColumn IsReadOnly="True" Width="*" Header="Publisher" Binding="{Binding Publisher}" />
                    <DataGridTextColumn IsReadOnly="True" Width="100" Header="Publication date" Binding="{Binding PublicationDate}" />
                    <DataGridTextColumn IsReadOnly="True" Width="*" Header="Languages" Binding="{Binding Languages}" />
                    <DataGridTextColumn IsReadOnly="True" Width="*" Header="Series/index" Binding="{Binding Series}" />
                    <DataGridTextColumn IsReadOnly="True" Width="80" Header="Cover flag" Binding="{Binding HasCover}" />
                    <DataGridTextColumn IsReadOnly="True" Width="3*" Header="Metadata quality facts" Binding="{Binding MetadataQualityFacts}" />
                    <DataGridTextColumn IsReadOnly="True" Width="2*" Header="Formats/status" Binding="{Binding Formats}" />
                    <DataGridTextColumn IsReadOnly="True" Width="2*" Header="Identifiers (context)" Binding="{Binding Identifiers}" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="_Format selections">
              <DataGrid Margin="4" ItemsSource="{Binding SelectedRecommendationFormats}" AutoGenerateColumns="False" EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling" AutomationProperties.Name="Format recommendation comparison">
                <DataGrid.Columns>
                  <DataGridTextColumn IsReadOnly="True" Width="75" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn IsReadOnly="True" Width="130" Header="Generated source" Binding="{Binding GeneratedSource}" />
                  <DataGridTemplateColumn Width="2*" Header="Reviewed source/action">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding ReviewedSource}" DisplayMemberPath="Label" /></DataTemplate></DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn IsReadOnly="True" Width="130" Header="Resolution" Binding="{Binding Resolution}" />
                  <DataGridTextColumn IsReadOnly="True" Width="100" Header="Strength" Binding="{Binding Strength}" />
                  <DataGridTextColumn IsReadOnly="True" Width="3*" Header="All candidates" Binding="{Binding Candidates}" />
                  <DataGridTextColumn IsReadOnly="True" Width="140" Header="Exact binary" Binding="{Binding ExactBinary}" />
                  <DataGridTextColumn IsReadOnly="True" Width="3*" Header="EPUB assessment (separate score)" Binding="{Binding EpubAssessment}" />
                  <DataGridTextColumn IsReadOnly="True" Width="2*" Header="Warnings" Binding="{Binding Warnings}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Reasons">
              <DataGrid Margin="4" ItemsSource="{Binding SelectedRecommendationReasons}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns><DataGridTextColumn Width="2*" Header="Code" Binding="{Binding Code}" /><DataGridTextColumn Width="*" Header="Subject" Binding="{Binding Subject}" /><DataGridTextColumn Width="4*" Header="Explanation" Binding="{Binding Explanation}" /><DataGridTextColumn Width="2*" Header="Evidence" Binding="{Binding Evidence}" /></DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Warnings">
              <DataGrid Margin="4" ItemsSource="{Binding SelectedRecommendationWarnings}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns><DataGridTextColumn Width="2*" Header="Code" Binding="{Binding Code}" /><DataGridTextColumn Width="100" Header="Severity" Binding="{Binding Severity}" /><DataGridTextColumn Width="*" Header="Subject" Binding="{Binding Subject}" /><DataGridTextColumn Width="4*" Header="Manual-review warning" Binding="{Binding Explanation}" /><DataGridTextColumn Width="2*" Header="Evidence" Binding="{Binding Evidence}" /></DataGrid.Columns>
              </DataGrid>
            </TabItem>
          </TabControl>
        </Grid>
      </TabItem>
      <TabItem Header="_Cleanup plans" AutomationProperties.Name="Non-executable cleanup plans">
        <Grid Margin="8" DataContext="{Binding CleanupPlans}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0">
            <TextBlock Text="Cleanup plans are immutable descriptive artifacts. Approval creates no backup and makes no Calibre change."
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="Cleanup plan safety boundary" />
            <WrapPanel Margin="0,8,0,4">
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Generate" Command="{Binding GenerateCommand}" AutomationProperties.HelpText="Generate from the current explicitly reviewed recommendation" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Validate" Command="{Binding ValidateCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Approve" Command="{Binding ApproveCommand}" AutomationProperties.HelpText="Approve the exact immutable body digest" />
              <Label Target="{Binding ElementName=RevocationReasonBox}" Content="_Revocation reason:" />
              <TextBox x:Name="RevocationReasonBox" Width="240" Margin="4,0,6,0" Text="{Binding RevocationReason, UpdateSourceTrigger=PropertyChanged}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Revoke" Command="{Binding RevokeCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Export" Command="{Binding ExportCommand}" />
              <Button Padding="8,4" Content="_Import" Command="{Binding ImportCommand}" />
            </WrapPanel>
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" AutomationProperties.Name="Cleanup plan status" />
          </StackPanel>
          <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="3*" /></Grid.ColumnDefinitions>
            <GroupBox Header="Plan revisions">
              <DataGrid ItemsSource="{Binding Plans}" SelectedItem="{Binding SelectedPlan}" AutoGenerateColumns="False" IsReadOnly="True"
                        EnableRowVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling"
                        AutomationProperties.Name="Cleanup plan immutable revisions">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="2*" Header="Plan ID" Binding="{Binding PlanId}" />
                  <DataGridTextColumn Width="70" Header="Revision" Binding="{Binding Revision}" />
                  <DataGridTextColumn Width="90" Header="State" Binding="{Binding State}" />
                  <DataGridTextColumn Width="80" Header="Target" Binding="{Binding TargetRecordId}" />
                  <DataGridTextColumn Width="2*" Header="Approval" Binding="{Binding ApprovalState}" />
                </DataGrid.Columns>
              </DataGrid>
            </GroupBox>
            <GroupBox Grid.Column="1" Margin="8,0,0,0" Header="Selected plan identity and provenance">
              <StackPanel Margin="6">
                <TextBlock Text="{Binding PlanIdentity}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding PlanTimes}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding ContentDigest}" TextWrapping="Wrap" AutomationProperties.Name="Canonical immutable body SHA-256" />
                <TextBlock Margin="0,3,0,0" Text="{Binding SourceIdentity}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding GroupAndMembers}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding TargetAndMetadata}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding ProvenanceSummary}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding OverrideSummary}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding ApprovalSummary}" TextWrapping="Wrap" />
                <TextBlock Margin="0,3,0,0" Text="{Binding RevocationSummary}" TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>
          </Grid>
          <TabControl Grid.Row="2" Margin="0,8,0,0">
            <TabItem Header="_Retentions">
              <DataGrid ItemsSource="{Binding FormatRetentions}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="80" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="80" Header="Source" Binding="{Binding SourceRecordId}" />
                  <DataGridTextColumn Width="80" Header="Target" Binding="{Binding TargetRecordId}" />
                  <DataGridTextColumn Width="2*" Header="Source relative path" Binding="{Binding SourcePath}" />
                  <DataGridTextColumn Width="100" Header="Length" Binding="{Binding Length}" />
                  <DataGridTextColumn Width="3*" Header="Expected SHA-256" Binding="{Binding Sha256}" />
                  <DataGridTextColumn Width="150" Header="Retention mode" Binding="{Binding Mode}" />
                  <DataGridTextColumn Width="3*" Header="Preconditions" Binding="{Binding Preconditions}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="Format _removals">
              <DataGrid ItemsSource="{Binding FormatRemovals}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="80" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="80" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="2*" Header="Expected relative path" Binding="{Binding RelativePath}" />
                  <DataGridTextColumn Width="2*" Header="Reviewed classification" Binding="{Binding Reason}" />
                  <DataGridTextColumn Width="2*" Header="Retained destination" Binding="{Binding RetainedInstruction}" />
                  <DataGridTextColumn Width="2*" Header="Required backup" Binding="{Binding BackupRequirement}" />
                  <DataGridCheckBoxColumn Width="100" Header="Byte-identical" Binding="{Binding ByteIdentical}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Record removals">
              <DataGrid ItemsSource="{Binding RecordRemovals}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="80" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="3*" Header="Backup requirements" Binding="{Binding BackupRequirements}" />
                  <DataGridTextColumn Width="2*" Header="Preserved contributions" Binding="{Binding RequiredRetentions}" />
                  <DataGridTextColumn Width="4*" Header="Preconditions" Binding="{Binding Preconditions}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="Expected _records">
              <DataGrid ItemsSource="{Binding ExpectedRecords}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="70" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="2*" Header="Stored title" Binding="{Binding Title}" />
                  <DataGridTextColumn Width="2*" Header="Stored authors/IDs" Binding="{Binding Authors}" />
                  <DataGridTextColumn Width="2*" Header="Identifiers" Binding="{Binding Identifiers}" />
                  <DataGridTextColumn Width="2*" Header="Publication/series" Binding="{Binding Publication}" />
                  <DataGridTextColumn Width="*" Header="Languages" Binding="{Binding Languages}" />
                  <DataGridTextColumn Width="*" Header="Cover state" Binding="{Binding Cover}" />
                  <DataGridTextColumn Width="2*" Header="Managed directory" Binding="{Binding RelativeDirectory}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="Expected _files">
              <DataGrid ItemsSource="{Binding ExpectedFormats}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="70" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="70" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="*" Header="Stored name" Binding="{Binding StoredName}" />
                  <DataGridTextColumn Width="2*" Header="Relative path" Binding="{Binding RelativePath}" />
                  <DataGridTextColumn Width="90" Header="Status" Binding="{Binding Status}" />
                  <DataGridTextColumn Width="90" Header="Length" Binding="{Binding Length}" />
                  <DataGridTextColumn Width="3*" Header="SHA-256" Binding="{Binding Sha256}" />
                  <DataGridTextColumn Width="150" Header="Created UTC" Binding="{Binding CreationTimeUtc}" />
                  <DataGridTextColumn Width="150" Header="Written UTC" Binding="{Binding LastWriteTimeUtc}" />
                  <DataGridTextColumn Width="90" Header="Attributes" Binding="{Binding Attributes}" />
                  <DataGridTextColumn Width="180" Header="Observation source" Binding="{Binding ObservationSourceVersion}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Backups">
              <DataGrid ItemsSource="{Binding BackupRequirements}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="2*" Header="Requirement ID" Binding="{Binding Id}" />
                  <DataGridTextColumn Width="2*" Header="Kind" Binding="{Binding Kind}" />
                  <DataGridTextColumn Width="80" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="80" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="2*" Header="Status" Binding="{Binding Status}" />
                  <DataGridTextColumn Width="4*" Header="Requirement" Binding="{Binding Explanation}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Issues">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <DataGrid ItemsSource="{Binding Issues}" AutoGenerateColumns="False" IsReadOnly="True" AutomationProperties.Name="Current cleanup plan blocking errors warnings and information">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="130" Header="Severity" Binding="{Binding Severity}" />
                    <DataGridTextColumn Width="2*" Header="Code" Binding="{Binding Code}" />
                    <DataGridTextColumn Width="2*" Header="Subject" Binding="{Binding Subject}" />
                    <DataGridTextColumn Width="4*" Header="Explanation" Binding="{Binding Explanation}" />
                  </DataGrid.Columns>
                </DataGrid>
                <DataGrid Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding GenerationIssues}" AutoGenerateColumns="False" IsReadOnly="True" AutomationProperties.Name="Cleanup plan generation issues when no plan was produced">
                  <DataGrid.Columns>
                    <DataGridTextColumn Width="130" Header="Severity" Binding="{Binding Severity}" />
                    <DataGridTextColumn Width="2*" Header="Code" Binding="{Binding Code}" />
                    <DataGridTextColumn Width="2*" Header="Subject" Binding="{Binding Subject}" />
                    <DataGridTextColumn Width="4*" Header="Explanation" Binding="{Binding Explanation}" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="_Lifecycle">
              <DataGrid ItemsSource="{Binding LifecycleHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="80" Header="Revision" Binding="{Binding Revision}" />
                  <DataGridTextColumn Width="2*" Header="Transition" Binding="{Binding Transition}" />
                  <DataGridTextColumn Width="160" Header="Changed UTC" Binding="{Binding ChangedAtUtc}" />
                  <DataGridTextColumn Width="4*" Header="Audit reason" Binding="{Binding Reason}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
          </TabControl>
        </Grid>
      </TabItem>
      <TabItem Header="Cleanup _execution" AutomationProperties.Name="Safe single-plan Calibre execution">
        <Grid Margin="8" DataContext="{Binding CleanupExecutions}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0">
            <TextBlock FontWeight="Bold" TextWrapping="Wrap"
                       Text="Milestone 7 can modify this Calibre library. It executes one approved plan through direct supported Calibre commands only, after fresh scans and complete verified external backups. Automatic rollback is not available."
                       AutomationProperties.Name="Real mutation safety warning" />
            <TextBlock Margin="0,5,0,0" Text="{Binding LibrarySummary}" TextWrapping="Wrap" />
            <TextBlock Margin="0,3,0,0" Text="{Binding PlanSummary}" TextWrapping="Wrap" />
            <TextBlock Margin="0,3,0,0" Text="{Binding PlanDigest}" TextWrapping="Wrap" AutomationProperties.Name="Approved plan canonical SHA-256" />
            <TextBlock Margin="0,3,0,0" Text="{Binding ImportedApprovalNotice}" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Margin="0,3,0,0" Text="{Binding CompatibilitySummary}" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Row="1" Margin="0,8,0,4">
            <WrapPanel>
              <Button Margin="0,0,6,0" Padding="8,4" Content="Choose _backup folder" Command="{Binding ChooseBackupCommand}" />
              <TextBox Width="420" Margin="0,0,6,0" IsReadOnly="True" Text="{Binding BackupDestination}" AutomationProperties.Name="External verified backup location" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Prepare and preflight" Command="{Binding PrepareCommand}" />
              <Button Margin="0,0,6,0" Padding="8,4" Content="_Execute one plan" Command="{Binding ExecuteCommand}" />
              <Button Padding="8,4" Content="{Binding CancelActionText}" Command="{Binding CancelOrSafeStopCommand}" />
            </WrapPanel>
            <CheckBox Margin="0,5,0,0" IsChecked="{Binding OtherMutatorsClosed}"
                      Content="I confirm that Calibre and every other library-mutating tool are closed." />
            <CheckBox Margin="0,3,0,0" IsChecked="{Binding RecoveryLimitationsAccepted}"
                      Content="I understand that cancellation is delayed after mutation begins and Milestone 7 cannot automatically roll back or resume." />
            <ProgressBar Height="16" Margin="0,6,0,0" Minimum="0" Maximum="100" Value="{Binding ProgressPercentage}" />
            <TextBlock Margin="0,3,0,0" Text="{Binding ProgressMessage}" TextWrapping="Wrap" />
            <TextBlock Margin="0,3,0,0" Text="{Binding Status}" FontWeight="Bold" TextWrapping="Wrap" />
            <TextBlock Margin="0,3,0,0" Text="{Binding ResultSummary}" FontWeight="Bold" TextWrapping="Wrap" AutomationProperties.Name="Execution terminal result" />
            <TextBlock Margin="0,3,0,0" Text="{Binding ArtifactSummary}" TextWrapping="Wrap" />
          </StackPanel>
          <TabControl Grid.Row="2" Margin="0,6,0,0">
            <TabItem Header="Planned _effects">
              <DataGrid ItemsSource="{Binding Effects}" AutoGenerateColumns="False" IsReadOnly="True"
                        EnableRowVirtualization="True" AutomationProperties.Name="Formats to add replace and remove and records to remove">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="150" Header="Effect" Binding="{Binding Effect}" />
                  <DataGridTextColumn Width="90" Header="Record" Binding="{Binding RecordId}" />
                  <DataGridTextColumn Width="90" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="4*" Header="Exact consequence and supported command behavior" Binding="{Binding Detail}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="_Ordered operations">
              <DataGrid ItemsSource="{Binding Operations}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                        EnableRowVirtualization="True" AutomationProperties.Name="Dependency ordered execution operations">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="110" Header="Phase" Binding="{Binding Phase}" />
                  <DataGridTextColumn Width="180" Header="Operation" Binding="{Binding Operation}" />
                  <DataGridTextColumn Width="80" Header="Target" Binding="{Binding TargetRecordId}" />
                  <DataGridTextColumn Width="80" Header="Source" Binding="{Binding SourceRecordId}" />
                  <DataGridTextColumn Width="80" Header="Format" Binding="{Binding Format}" />
                  <DataGridTextColumn Width="3*" Header="Exact effect" Binding="{Binding Effect}" />
                  <DataGridTextColumn Width="3*" Header="Dependencies" Binding="{Binding Dependencies}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
            <TabItem Header="Preflight and execution _issues">
              <DataGrid ItemsSource="{Binding Issues}" AutoGenerateColumns="False" IsReadOnly="True"
                        AutomationProperties.Name="Execution blocking errors warnings and information">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="120" Header="Severity" Binding="{Binding Severity}" />
                  <DataGridTextColumn Width="2*" Header="Code" Binding="{Binding Code}" />
                  <DataGridTextColumn Width="*" Header="Subject" Binding="{Binding Subject}" />
                  <DataGridTextColumn Width="4*" Header="Explanation" Binding="{Binding Explanation}" />
                </DataGrid.Columns>
              </DataGrid>
            </TabItem>
          </TabControl>
          <GroupBox Grid.Row="3" Margin="0,8,0,0" Header="Execution history">
            <DockPanel>
              <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="4" Padding="8,4"
                      Content="_Refresh history" Command="{Binding RefreshHistoryCommand}" />
              <DataGrid ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True" EnableRowVirtualization="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Width="2*" Header="Execution ID" Binding="{Binding ExecutionId}" />
                  <DataGridTextColumn Width="130" Header="State" Binding="{Binding State}" />
                  <DataGridTextColumn Width="130" Header="Disposition" Binding="{Binding Disposition}" />
                  <DataGridTextColumn Width="150" Header="Failure" Binding="{Binding Failure}" />
                  <DataGridTextColumn Width="160" Header="Finished UTC" Binding="{Binding FinishedAtUtc}" />
                  <DataGridCheckBoxColumn Width="100" Header="Mutation began" Binding="{Binding MutationStarted}" />
                  <DataGridTextColumn Width="3*" Header="Recovery bundle" Binding="{Binding BundlePath}" />
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </GroupBox>
        </Grid>
      </TabItem>
      <TabItem Header="_EPUB assessments" AutomationProperties.Name="EPUB assessments">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DataGrid Grid.Row="0"
                    ItemsSource="{Binding EpubAssessments}"
                    SelectedItem="{Binding SelectedEpubAssessment}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single"
                    AutomationProperties.Name="EPUB assessment summary">
            <DataGrid.Columns>
              <DataGridTextColumn Width="70" Header="Book ID" Binding="{Binding BookId}" />
              <DataGridTextColumn Width="*" Header="Calibre title (context)" Binding="{Binding BookTitle}" />
              <DataGridTextColumn Width="2*" Header="Expected path" Binding="{Binding ExpectedRelativePath}" />
              <DataGridTextColumn Width="110" Header="Status" Binding="{Binding Status}" />
              <DataGridTextColumn Width="150" Header="Score" Binding="{Binding Score}" />
              <DataGridTextColumn Width="70" Header="Opened" Binding="{Binding Opened}" />
              <DataGridTextColumn Width="100" Header="Package" Binding="{Binding PackageParsed}" />
              <DataGridTextColumn Width="80" Header="EPUB" Binding="{Binding PackageVersion}" />
              <DataGridTextColumn Width="140" Header="Analyzer" Binding="{Binding AnalyzerVersion}" />
              <DataGridTextColumn Width="140" Header="Scoring model" Binding="{Binding ScoringModelVersion}" />
            </DataGrid.Columns>
          </DataGrid>
          <TextBlock Grid.Row="1" Margin="0,8,0,4" TextWrapping="Wrap" Text="{Binding EpubDisqualificationMessage}" FontWeight="Bold" AutomationProperties.Name="EPUB disqualification status" />
          <TextBlock Grid.Row="2" Margin="0,4,0,8" TextWrapping="Wrap" Text="{Binding SelectedEpubFeatureSummary}" AutomationProperties.Name="Selected EPUB bounded feature summary" />
          <Grid Grid.Row="3">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
              <Label Target="{Binding ElementName=EpubFindingFilter}" Content="Finding _severity:" />
              <ComboBox x:Name="EpubFindingFilter" MinWidth="140" ItemsSource="{Binding EpubFindingFilterModes}" SelectedItem="{Binding EpubFindingFilterMode}" AutomationProperties.Name="Filter EPUB findings by severity" />
            </StackPanel>
            <DataGrid Grid.Row="1" ItemsSource="{Binding EpubFindings}" AutoGenerateColumns="False" IsReadOnly="True" AutomationProperties.Name="EPUB assessment findings">
              <DataGrid.Columns>
                <DataGridTextColumn Width="110" Header="Severity" Binding="{Binding Severity}" />
                <DataGridTextColumn Width="220" Header="Rule" Binding="{Binding RuleId}" />
                <DataGridTextColumn Width="90" Header="Adjustment" Binding="{Binding Adjustment}" />
                <DataGridTextColumn Width="2*" Header="Explanation" Binding="{Binding Explanation}" />
                <DataGridTextColumn Width="2*" Header="Evidence" Binding="{Binding Evidence}" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
