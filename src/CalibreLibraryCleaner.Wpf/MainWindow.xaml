<Window x:Class="CalibreLibraryCleaner.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibre Library Cleaner"
        Width="1100"
        Height="700"
        MinWidth="760"
        MinHeight="480">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="2*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0"
             Target="{Binding ElementName=LibraryPathBox}"
             Content="_Library folder:" />
      <TextBox x:Name="LibraryPathBox"
               Grid.Column="1"
               Margin="4,0,8,0"
               Padding="4"
               IsReadOnly="True"
               Text="{Binding SelectedLibraryPath}"
               AutomationProperties.Name="Selected Calibre library folder" />
      <Button Grid.Column="2"
              MinWidth="80"
              Margin="0,0,8,0"
              Padding="8,4"
              Content="_Browse..."
              Command="{Binding SelectLibraryCommand}"
              AutomationProperties.Name="Browse for Calibre library" />
      <Button Grid.Column="3"
              MinWidth="80"
              Margin="0,0,8,0"
              Padding="8,4"
              Content="_Scan"
              Command="{Binding ScanCommand}" />
      <Button Grid.Column="4"
              MinWidth="80"
              Padding="8,4"
              Content="_Cancel"
              Command="{Binding CancelCommand}" />
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,12,0,0">
      <ProgressBar Height="16"
                   Minimum="0"
                   Maximum="100"
                   Value="{Binding ProgressPercentage}"
                   IsIndeterminate="{Binding IsProgressIndeterminate}"
                   AutomationProperties.Name="Library scan progress" />
      <TextBlock Margin="0,4,0,0"
                 Text="{Binding StatusMessage}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="2"
            Margin="0,12,0,0"
            Padding="8"
            BorderBrush="DarkRed"
            BorderThickness="1">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel>
        <TextBlock FontWeight="Bold"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding ErrorAction}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <GroupBox Grid.Row="3" Margin="0,12,0,0" Header="Books">
      <DataGrid ItemsSource="{Binding Books}"
                SelectedItem="{Binding SelectedBook}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionMode="Single"
                AutomationProperties.Name="Loaded books">
        <DataGrid.Columns>
          <DataGridTextColumn Width="70" Header="ID" Binding="{Binding Id}" />
          <DataGridTextColumn Width="2*" Header="Title" Binding="{Binding Title}" />
          <DataGridTextColumn Width="2*" Header="Authors" Binding="{Binding Authors}" />
          <DataGridTextColumn Width="2*" Header="Author sort" Binding="{Binding AuthorSort}" />
          <DataGridTextColumn Width="3*" Header="Managed directory" Binding="{Binding RelativeDirectory}" />
        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>

    <GroupBox Grid.Row="4" Margin="0,12,0,0" Header="Formats for selected book">
      <DataGrid ItemsSource="{Binding SelectedFormats}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                AutomationProperties.Name="Formats for selected book">
        <DataGrid.Columns>
          <DataGridTextColumn Width="100" Header="Format" Binding="{Binding Format}" />
          <DataGridTextColumn Width="2*" Header="Stored name" Binding="{Binding StoredFileName}" />
          <DataGridTextColumn Width="4*" Header="Expected relative path" Binding="{Binding ExpectedRelativePath}" />
          <DataGridTextColumn Width="120" Header="File status" Binding="{Binding Status}" />
        </DataGrid.Columns>
      </DataGrid>
    </GroupBox>
  </Grid>
</Window>
